# --- Supabase / PostgreSQL ---
# URL principal (usa el Transaction Pooler de Supabase, puerto 6543)
# Encuéntrala en: Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.XXXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# URL directa (conexión directa, puerto 5432) — usada por Prisma Migrate
# Encuéntrala en: Supabase Dashboard → Project Settings → Database → Connection string → URI
DIRECT_URL=postgresql://postgres:PASSWORD@db.XXXXXX.supabase.co:5432/postgres?sslmode=require

# --- Autenticación JWT ---
# Secreto para firmar los tokens. Usa una cadena larga y aleatoria.
JWT_SECRET=reemplaza_con_un_secreto_seguro
