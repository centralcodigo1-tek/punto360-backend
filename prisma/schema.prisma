generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model audit_logs {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?   @db.Uuid
  action     String?
  entity     String?
  entity_id  String?   @db.Uuid
  old_data   Json?
  new_data   Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model branches {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String?               @db.Uuid
  name                String
  address             String?
  phone               String?
  is_main             Boolean?              @default(false)
  is_active           Boolean?              @default(true)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  code                String?               @unique
  companies           companies?            @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  cash_registers      cash_registers[]
  cartera_movements   cartera_movements[]
  expenses            expenses[]
  inventory_movements inventory_movements[]
  purchases           purchases[]
  sales               sales[]
  stock               stock[]
  variant_stock       variant_stock[]
  user_branches       user_branches[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cash_movements {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cash_register_id String?         @db.Uuid
  user_id          String?         @db.Uuid
  type             String?
  amount           Decimal?        @db.Decimal(12, 2)
  reason           String?
  created_at       DateTime?       @default(now()) @db.Timestamp(6)
  cash_registers   cash_registers? @relation(fields: [cash_register_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users?          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model cash_registers {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branch_id        String?          @db.Uuid
  company_id       String?          @db.Uuid
  user_id          String?          @db.Uuid
  name             String?
  status           String?          @default("CLOSED")
  opening_amount   Decimal?         @db.Decimal(12, 2)
  closing_amount   Decimal?         @db.Decimal(12, 2)
  notes            String?
  opened_at        DateTime?        @db.Timestamp(6)
  closed_at        DateTime?        @db.Timestamp(6)
  cash_movements   cash_movements[]
  branches         branches?        @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies        companies?       @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users?           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model categories {
  id         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id String?    @db.Uuid
  name       String
  is_active  Boolean?   @default(true)
  companies  companies? @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products[]
}

model companies {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  document_number String?
  phone           String?
  email           String?
  address         String?
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  branches        branches[]
  categories      categories[]
  customers       customers[]
  expenses        expenses[]
  products        products[]
  sales           sales[]
  suppliers       suppliers[]
  users           users[]
  roles           roles[]
  cash_registers  cash_registers[]
  cartera_movements cartera_movements[]
  subscriptions   subscriptions[]
}

model customers {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id        String?             @db.Uuid
  name              String
  phone             String?
  email             String?
  credit_limit      Decimal?            @db.Decimal(12, 2)
  notes             String?
  is_active         Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  companies         companies?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales             sales[]
  customer_payments customer_payments[]
}

model customer_payments {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id    String     @db.Uuid
  user_id        String?    @db.Uuid
  amount         Decimal    @db.Decimal(12, 2)
  payment_method String?    @default("CASH")
  notes          String?
  created_at     DateTime?  @default(now()) @db.Timestamp(6)
  customers      customers  @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model expenses {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String?    @db.Uuid
  branch_id   String?    @db.Uuid
  description String?
  amount      Decimal?   @db.Decimal(12, 2)
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  branches    branches?  @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies   companies? @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_movements {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id   String?   @db.Uuid
  branch_id    String?   @db.Uuid
  type         String?
  quantity     Decimal?  @db.Decimal(12, 3)
  reason       String?
  reference_id String?   @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  branches     branches? @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products     products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model products {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String?               @db.Uuid
  category_id         String?               @db.Uuid
  name                String
  sku                 String
  cost_price          Decimal?              @default(0) @db.Decimal(12, 2)
  sale_price          Decimal               @db.Decimal(12, 2)
  unit_type           String?               @default("UNIT")
  is_active           Boolean?              @default(true)
  is_consignment      Boolean?              @default(false)
  has_variants        Boolean               @default(false)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  inventory_movements inventory_movements[]
  categories          categories?           @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies           companies?            @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  purchase_items      purchase_items[]
  sale_items          sale_items[]
  stock               stock[]
  product_attributes  product_attributes[]
  product_variants    product_variants[]

  @@unique([company_id, sku])
}

model product_attributes {
  id         String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id String             @db.Uuid
  name       String
  position   Int                @default(0)
  products   products           @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  values     attribute_values[]
}

model attribute_values {
  id             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  attribute_id   String                    @db.Uuid
  value          String
  position       Int                       @default(0)
  attribute      product_attributes        @relation(fields: [attribute_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variant_values variant_attribute_values[]
}

model product_variants {
  id             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id     String                    @db.Uuid
  sku            String
  cost_price     Decimal                   @default(0) @db.Decimal(12, 2)
  sale_price     Decimal                   @db.Decimal(12, 2)
  is_default     Boolean                   @default(false)
  is_active      Boolean                   @default(true)
  created_at     DateTime?                 @default(now()) @db.Timestamp(6)
  products       products                  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  values         variant_attribute_values[]
  stock          variant_stock[]
  sale_items     sale_items[]

  @@unique([product_id, sku])
}

model variant_attribute_values {
  variant_id         String           @db.Uuid
  attribute_value_id String           @db.Uuid
  variant            product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attribute_value    attribute_values @relation(fields: [attribute_value_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([variant_id, attribute_value_id])
}

model variant_stock {
  id         String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  variant_id String           @db.Uuid
  branch_id  String           @db.Uuid
  quantity   Decimal          @default(0) @db.Decimal(12, 3)
  updated_at DateTime?        @default(now()) @db.Timestamp(6)
  variants   product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branches   branches         @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([variant_id, branch_id])
}

model purchase_items {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  purchase_id String?    @db.Uuid
  product_id  String?    @db.Uuid
  quantity    Decimal?   @db.Decimal(12, 3)
  cost        Decimal?   @db.Decimal(12, 2)
  products    products?  @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchases   purchases? @relation(fields: [purchase_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model purchases {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  supplier_id      String?          @db.Uuid
  branch_id        String?          @db.Uuid
  total            Decimal?         @db.Decimal(12, 2)
  paid_amount      Decimal?         @default(0) @db.Decimal(12, 2)
  status           String?          @default("PAID")
  due_date         DateTime?        @db.Timestamp(6)
  created_at       DateTime?        @default(now()) @db.Timestamp(6)
  purchase_items   purchase_items[]
  purchase_payments purchase_payments[]
  branches         branches?        @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  suppliers        suppliers?       @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model purchase_payments {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  purchase_id    String?    @db.Uuid
  user_id        String?    @db.Uuid
  amount         Decimal?   @db.Decimal(12, 2)
  payment_method String?
  notes          String?
  created_at     DateTime?  @default(now()) @db.Timestamp(6)
  purchases      purchases? @relation(fields: [purchase_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model roles {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id       String?            @db.Uuid
  name             String
  companies        companies?         @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role_permissions role_permissions[]
  user_roles       user_roles[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sale_items {
  id         String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sale_id    String?           @db.Uuid
  product_id String?           @db.Uuid
  variant_id String?           @db.Uuid
  quantity   Decimal?          @db.Decimal(12, 3)
  price      Decimal?          @db.Decimal(12, 2)
  subtotal   Decimal?          @db.Decimal(12, 2)
  products   products?         @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variants   product_variants? @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales      sales?            @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model sales {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id     String?      @db.Uuid
  branch_id      String?      @db.Uuid
  user_id        String?      @db.Uuid
  customer_id    String?      @db.Uuid
  total          Decimal      @db.Decimal(12, 2)
  payment_method String?
  status         String?      @default("PAID")
  is_credit      Boolean?     @default(false)
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  sale_items     sale_items[]
  branches       branches?    @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies      companies?   @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers      customers?   @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model stock {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id String?   @db.Uuid
  branch_id  String?   @db.Uuid
  quantity   Decimal   @default(0) @db.Decimal(12, 3)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  branches   branches? @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, branch_id])
}

model suppliers {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id String?     @db.Uuid
  name       String
  phone      String?
  email      String?
  purchases  purchases[]
  companies  companies?  @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model user_roles {
  user_id String @db.Uuid
  role_id String @db.Uuid
  roles   roles  @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users   users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, role_id])
}

model user_branches {
  user_id   String   @db.Uuid
  branch_id String   @db.Uuid
  branches  branches @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, branch_id])
}

model cartera_movements {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id     String     @db.Uuid
  branch_id      String?    @db.Uuid
  user_id        String?    @db.Uuid
  type           String
  amount         Decimal    @db.Decimal(12, 2)
  reason         String
  reference_id   String?    @db.Uuid
  reference_type String?
  created_at     DateTime?  @default(now()) @db.Timestamp(6)
  companies      companies  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branches       branches?  @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id     String?          @db.Uuid
  name           String
  email          String           @unique
  password_hash  String
  is_active      Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  user_name      String?
  audit_logs          audit_logs[]
  cash_movements      cash_movements[]
  cash_registers      cash_registers[]
  cartera_movements   cartera_movements[]
  sales               sales[]
  user_roles          user_roles[]
  user_branches       user_branches[]
  purchase_payments   purchase_payments[]
  customer_payments   customer_payments[]
  companies           companies?          @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model subscriptions {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id String    @db.Uuid
  start_date DateTime  @db.Timestamp(6)
  end_date   DateTime  @db.Timestamp(6)
  amount     Decimal   @default(800000) @db.Decimal(12, 2)
  status     String    @default("active")
  notes      String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model permissions {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key              String             @unique
  name             String
  role_permissions role_permissions[]
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_permission")
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_role")

  @@id([role_id, permission_id])
}
